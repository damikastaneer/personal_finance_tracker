<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="552.0" prefWidth="700.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="nl.dami.fintrack.controller.MainController">

   <left>
      <VBox prefWidth="220" styleClass="sidebar">
         <Label styleClass="app-title" text="FinTrack" />
         <Button styleClass="sidebar-button" text="Overview" />
         <Button styleClass="sidebar-button" text="Transactions" />
         <Button styleClass="sidebar-button" text="Budgets" />
         <Button styleClass="sidebar-button" text="Reports" />
         <Button styleClass="sidebar-button" text="Settings" />
      </VBox>
   </left>

   <center>
      <VBox prefWidth="539.0" spacing="24" styleClass="main-content">
         <Label styleClass="page-title" text="Dashboard" />

         <HBox spacing="20">
            <VBox styleClass="card">
               <Label styleClass="title-label" text="Current Balance" />
               <Label styleClass="balance-label" text="€0.00" />
            </VBox>

            <VBox styleClass="card">
               <Label styleClass="title-label" text="Income" />
               <Label styleClass="balance-label" text="€0.00" />
            </VBox>

            <VBox styleClass="card">
               <Label styleClass="title-label" text="Expenses" />
               <Label styleClass="balance-label" text="€0.00" />
            </VBox>
         </HBox>
         <VBox styleClass="card">

            <Label text="Recent Transactions"
                   styleClass="title-label"/>

            <TableView fx:id="transactionTable" prefHeight="246.0" prefWidth="416.0">
               <columns>
                  <TableColumn fx:id="dateColumn" prefWidth="108.0" text="Date" />
                  <TableColumn fx:id="typeColumn" prefWidth="94.0" text="Type" />
                  <TableColumn fx:id="categoryColumn" prefWidth="86.0" text="Category" />
                  <TableColumn fx:id="amountColumn" prefWidth="85.0" text="Amount" />
                  <TableColumn fx:id="descriptionColumn" prefWidth="120.0" text="Description" />
               </columns>
            </TableView>
         </VBox>


         <Button onAction="#goToAddTransaction" styleClass="primary-button" text="Add Transaction" />
      </VBox>
   </center>

</BorderPane>
