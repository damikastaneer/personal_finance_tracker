<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0"
            prefWidth="500.0"
            styleClass="auth-root"
            stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="nl.dami.fintrack.controller.AddTransactionController">

    <children>
        <VBox alignment="CENTER"
              layoutX="75.0"
              layoutY="35.0"
              prefWidth="350.0"
              spacing="14"
              styleClass="auth-card">

            <children>
                <Label text="Add Transaction"
                       styleClass="auth-title"/>

                <TextField fx:id="amountField"
                           promptText="Amount"
                           styleClass="input-field"/>

                <ComboBox fx:id="typeComboBox"
                          prefWidth="350.0"
                          promptText="Type"
                          styleClass="input-field"/>

                <ComboBox fx:id="categoryComboBox"
                          prefWidth="350.0"
                          promptText="Category"
                          styleClass="input-field"/>

                <TextField fx:id="descriptionField"
                           promptText="Description"
                           styleClass="input-field"/>

                <DatePicker fx:id="datePicker"
                            prefWidth="350.0"/>

                <Label fx:id="messageLabel"
                       styleClass="message-label"/>

                <Button text="Save Transaction"
                        onAction="#handleSaveTransaction"
                        prefWidth="220.0"
                        styleClass="primary-button"/>

                <Button text="Back to Dashboard"
                        onAction="#goToDashboard"
                        prefWidth="220.0"
                        styleClass="secondary-button"/>
            </children>
        </VBox>
    </children>
</AnchorPane>