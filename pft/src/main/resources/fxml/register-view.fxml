<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>


<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<VBox stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="nl.dami.fintrack.controller.RegisterController">

   <HBox fx:id="windowBar" styleClass="window-bar">
      <Label text="FinTrack" styleClass="window-title"/>

      <Pane HBox.hgrow="ALWAYS"/>

      <Button text="—" onAction="#handleMinimize" styleClass="window-button"/>
      <Button text="□" onAction="#handleMaximize" styleClass="window-button"/>
      <Button text="✕" onAction="#handleClose" styleClass="close-button"/>
   </HBox>
   <AnchorPane prefHeight="620.0"
               prefWidth="500.0"
               styleClass="auth-root"
               stylesheets="@../css/style.css"
               xmlns="http://javafx.com/javafx/26"
               xmlns:fx="http://javafx.com/fxml/1"
               >

      <children>

         <VBox alignment="CENTER"
               layoutX="75.0"
               layoutY="25.0"
               prefWidth="350.0"
               spacing="14"
               styleClass="auth-card">

            <children>

               <Label text="FinTrack"
                      styleClass="auth-title" />

               <Label text="Create your account"
                      styleClass="subtitle-label" />

               <VBox spacing="6">

                  <children>

                     <Label text="First Name"
                            styleClass="field-label" />

                     <TextField fx:id="firstNameField"
                                prefHeight="42.0"
                                promptText="Enter your first name"
                                styleClass="input-field" />

                  </children>

               </VBox>

               <VBox spacing="6">

                  <children>

                     <Label text="Last Name"
                            styleClass="field-label" />

                     <TextField fx:id="lastNameField"
                                prefHeight="42.0"
                                promptText="Enter your last name"
                                styleClass="input-field" />

                  </children>

               </VBox>

               <VBox spacing="6">

                  <children>

                     <Label text="Username"
                            styleClass="field-label" />

                     <TextField fx:id="usernameField"
                                prefHeight="42.0"
                                promptText="Choose a username"
                                styleClass="input-field" />

                  </children>

               </VBox>

               <VBox spacing="6">

                  <children>

                     <Label text="Email"
                            styleClass="field-label" />

                     <TextField fx:id="emailField"
                                prefHeight="42.0"
                                promptText="Enter your email"
                                styleClass="input-field" />

                  </children>

               </VBox>

               <VBox spacing="6">

                  <children>

                     <Label text="Password"
                            styleClass="field-label" />

                     <PasswordField fx:id="passwordField"
                                    prefHeight="42.0"
                                    promptText="Create a password"
                                    styleClass="input-field" />

                  </children>

               </VBox>

               <VBox spacing="6">

                  <children>

                     <Label text="Confirm Password"
                            styleClass="field-label" />

                     <PasswordField fx:id="confirmPasswordField"
                                    prefHeight="42.0"
                                    promptText="Confirm your password"
                                    styleClass="input-field" />

                  </children>

               </VBox>

               <Label fx:id="messageLabel"
                      prefHeight="20.0"
                      styleClass="message-label" />

               <Button text="Create account"
                       onAction="#handleRegister"
                       prefHeight="42.0"
                       prefWidth="220.0"
                       styleClass="primary-button" />

               <Button text="Back to login"
                       onAction="#goToLogin"
                       prefHeight="42.0"
                       prefWidth="220.0"
                       styleClass="secondary-button" />

            </children>

         </VBox>

      </children>

   </AnchorPane>
</VBox>